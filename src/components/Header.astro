<header class="sticky top-0 z-50 bg-black/40 backdrop-blur-sm">
    <div class="flex items-center justify-between py-4 w-full max-w-280 mx-auto px-4">
        <div class="flex items-center gap-4">
            <img class="rounded-full w-10 h-10" src="/assets/mi-foto.jpg" alt="mi foto" />
        </div>

        <!-- Desktop nav -->
        <nav class="hidden md:flex flex-row gap-x-8 items-center text-sm opacity-90" aria-label="Main navigation">
            <a href="#top">Inicio</a>
            <a href="#proyectos">Proyectos</a>
            <a href="#sobre-mi">Sobre mí</a>
            <a href="#contacto">Contacto</a>
        </nav>

        <!-- Mobile: hamburger -->
        <div class="md:hidden">
            <button id="nav-toggle" aria-controls="mobile-menu" aria-expanded="false" aria-label="Abrir menú" class="p-2 rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-white">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
        </div>
    </div>

    <!-- Mobile menu panel -->
    <div id="mobile-menu" class="md:hidden hidden">
        <nav class="flex flex-col gap-2 py-3 px-4 bg-black/60 backdrop-blur-sm">
            <a href="#top" class="py-2">Inicio</a>
            <a href="#sobre-mi" class="py-2">Sobre mí</a>
            <a href="#proyectos" class="py-2">Proyectos</a>
            <a href="#contacto" class="py-2">Contacto</a>
        </nav>
    </div>

    <script is:inline>
        (() => {
            const btn = document.getElementById('nav-toggle');
            const menu = document.getElementById('mobile-menu');
            if (!btn || !menu) return;
            btn.addEventListener('click', () => {
                const expanded = btn.getAttribute('aria-expanded') === 'true';
                btn.setAttribute('aria-expanded', String(!expanded));
                menu.classList.toggle('hidden');
            });
        })();
    </script>
</header>
