---
const { href = '#', label = '' } = Astro.props;
---

<a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={label}
    class="inline-flex items-center gap-2 rounded-full border border-white/10 py-2 px-3 bg-white/5 hover:scale-105 hover:bg-white/10 transition-transform duration-200"
>
    <slot />
    {label ? <span class="hidden md:inline text-sm">{label}</span> : null}
</a>